# Opencode Go (OpenAI-compatible endpoint, optional, overrides Azure when set)
# Available models: glm-5.1, glm-5, kimi-k2.5, kimi-k2.6, deepseek-v4-pro, deepseek-v4-flash
OPENCODE_GO_API_KEY=
OPENCODE_GO_MODEL=glm-5.1

# Azure OpenAI (used by llm_classify and event handlers)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Microsoft Graph (Entra ID app registration)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_ID=me

# OneDrive (used for DOCX archive)
ONEDRIVE_DRIVE_ID=

# Storage backend: "json" (local) or "cosmos"
REPO_BACKEND=json
REPO_PATH=./out/repository.json
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DB=calorch
COSMOS_CONTAINER=events

# Durable LangGraph checkpoints (required for approval resume across restarts)
CHECKPOINT_POSTGRES_URI=

# HTTP API authentication (required when USE_MOCKS=false)
CALORCH_API_KEY=

# Enterprise data providers (license already held)
FACTSET_API_KEY=
BLOOMBERG_BLPAPI_HOST=
LSEG_CLIENT_ID=
SPGLOBAL_API_KEY=

# Use mock clients when credentials are missing (demo mode)
USE_MOCKS=true

# Where generated DOCX + email artefacts go
OUTPUT_DIR=./out

# LangSmith (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=calorch
LANGSMITH_TRACING=true
