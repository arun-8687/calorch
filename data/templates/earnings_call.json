{
  "schema_version": "1.0",
  "event_type": "earnings_call",
  "report_header": {
    "title": "EARNINGS PREP PACK",
    "company": "{company_name} ({primary_ticker})",
    "event": "{quarter} Earnings Call",
    "date": "{event_date} | {event_time}"
  },
  "footer": {
    "prepared_by": "Auto-generated by Calendar-Driven Workflow Orchestrator",
    "data_source": "SEC EDGAR, FRED, Tiingo, FOMC H.15 via Claude MCP",
    "generated": "{generated_at}"
  },
  "sections": [
    {
      "id": "executive_snapshot",
      "title": "Executive Snapshot",
      "source": "llm",
      "llm_method": "enrich_headline",
      "fallback": ["{primary_ticker} earnings — see data tables above."],
      "prompt_addendum": "Write a concise 3-4 bullet executive snapshot. Cover: revenue/EPS headline, guidance, key segment trends, and one notable surprise. Use numbers and percentages. Max 30 words per bullet."
    },
    {
      "id": "last_quarter",
      "title": "Last Quarter Performance ({last_quarter_label})",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "EPS Actual", "value": "{eps_actual}"},
        {"label": "EPS Estimate", "value": "{eps_estimate}"},
        {"label": "EPS Surprise", "value": "{eps_surprise}"},
        {"label": "Revenue Actual", "value": "{rev_actual}"},
        {"label": "Revenue Estimate", "value": "{rev_estimate}"},
        {"label": "Revenue Surprise", "value": "{rev_surprise}"}
      ]
    },
    {
      "id": "consensus",
      "title": "{next_quarter_label} Consensus Estimates",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "EPS Estimate (Avg)", "value": "{eps_q}"},
        {"label": "EPS Range", "value": "{eps_range}"},
        {"label": "Revenue Estimate (Avg)", "value": "{rev_q}"},
        {"label": "Revenue Range", "value": "{rev_range}"},
        {"label": "# Analysts (EPS)", "value": "{num_analysts}"}
      ]
    },
    {
      "id": "financial_metrics",
      "title": "Key Financial Metrics",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Gross Margin", "value": "{gross_margin}"},
        {"label": "Operating Margin", "value": "{operating_margin}"},
        {"label": "Net Margin", "value": "{net_margin}"},
        {"label": "ROE", "value": "{roe}"},
        {"label": "ROA", "value": "{roa}"}
      ]
    },
    {
      "id": "valuation",
      "title": "Valuation Multiples",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "P/E (TTM)", "value": "{pe_ttm}"},
        {"label": "Forward P/E", "value": "{forward_pe}"},
        {"label": "EV/EBITDA", "value": "{ev_ebitda}"},
        {"label": "Price/Sales", "value": "{price_sales}"},
        {"label": "Price/Book", "value": "{price_book}"}
      ]
    },
    {
      "id": "balance_sheet",
      "title": "Balance Sheet Highlights",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Cash & Equivalents", "value": "{cash}"},
        {"label": "Total Debt", "value": "{total_debt}"},
        {"label": "Net Debt", "value": "{net_debt}"},
        {"label": "Debt/Equity", "value": "{debt_equity}"},
        {"label": "Current Ratio", "value": "{current_ratio}"}
      ]
    },
    {
      "id": "product_segments",
      "title": "Revenue Segmentation",
      "subtitle": "By Product ({last_quarter_label})",
      "source": "data",
      "table_type": "two_col",
      "rows_from": "segments"
    },
    {
      "id": "geographic_segments",
      "title": "By Geography",
      "source": "data",
      "table_type": "two_col",
      "rows_from": "geo"
    },
    {
      "id": "analyst_sentiment",
      "title": "Analyst Sentiment & Fund Activity",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Consensus Rating", "value": "{consensus_rating}"},
        {"label": "Buy Ratings", "value": "{buy} ({buy_pct}%)"},
        {"label": "Hold Ratings", "value": "{hold} ({hold_pct}%)"},
        {"label": "Sell Ratings", "value": "{sell} ({sell_pct}%)"},
        {"label": "Price Target (Mean)", "value": "{mean_target}"}
      ]
    },
    {
      "id": "key_themes",
      "title": "Key Questions & Themes to Monitor",
      "source": "llm",
      "llm_method": "enrich_key_questions",
      "fallback": [],
      "prompt_addendum": "Write 6-8 themed bullet points of key questions and themes to monitor for this earnings call. Each should be a short paragraph (2-3 sentences) covering a specific theme like: demand, margins, guidance, competition, regulatory, new products, capital returns, geopolitical. Format as 'Theme: Question/content...'"
    },
    {
      "id": "esg",
      "title": "ESG Snapshot",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "ESG Risk Score", "value": "{esg_score}"},
        {"label": "Environmental", "value": "{esg_env}"},
        {"label": "Social", "value": "{esg_social}"},
        {"label": "Governance", "value": "{esg_gov}"}
      ]
    },
    {
      "id": "price_performance",
      "title": "Recent Price Performance",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Current Price", "value": "{price}"},
        {"label": "1-Week Change", "value": "{perf_1w}"},
        {"label": "1-Month Change", "value": "{perf_1m}"},
        {"label": "YTD Change", "value": "{perf_ytd}"},
        {"label": "52-Week Range", "value": "{range_52w}"}
      ]
    }
  ]
}
