# Opencode Go (OpenAI-compatible endpoint, optional, overrides Azure when set)
# Available models: glm-5.1, glm-5, kimi-k2.5, kimi-k2.6, deepseek-v4-pro, deepseek-v4-flash
OPENCODE_GO_API_KEY=
OPENCODE_GO_MODEL=glm-5.1

# Azure OpenAI (used by llm_classify and event handlers)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Microsoft Graph (Entra ID app registration)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_ID=me

# OneDrive (used for DOCX archive)
ONEDRIVE_DRIVE_ID=

# Delivery-idempotency store: "json" (local/dev) or "table" (production).
# "table" uses Azure Table Storage in the AZURE_STORAGE_* account below.
REPO_BACKEND=json
REPO_PATH=./out/repository.json
REPO_TABLE_NAME=calorchdelivery

# Timer schedule for the Durable Functions orchestrator (NCRONTAB, with seconds)
CRON_SCHEDULE=0 0 9 * * 1

# Approval workflow — when a send run pauses at the gate, these addresses get
# an email with a tokenized review-page link (Approve/Reject buttons).
# Leave empty to skip notification (the gate still works via the API).
APPROVER_EMAILS=
# Base URL for the emailed links; defaults to https://$WEBSITE_HOSTNAME on
# Azure, http://localhost:7071 locally.
APPROVAL_BASE_URL=

# Azure AI Search — institutional-knowledge RAG over the output corpus.
# Leave AZURE_SEARCH_ENDPOINT empty to disable RAG (no-op). When set, each
# enrichment LLM call is grounded in retrieved prior research, and each
# prepared analysis is indexed for future retrieval.
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_INDEX=calorch-knowledge
AZURE_SEARCH_API_KEY=
# Optional: name of a semantic configuration on the index for semantic ranking
AZURE_SEARCH_SEMANTIC_CONFIG=
RAG_TOP_K=4
# Push each prepared analysis into the index (the write side of the RAG loop)
KNOWLEDGE_WRITEBACK=true

# ---- Data sources: SEC EDGAR + AlphaSense only ----
# SEC EDGAR (free, fair-use) — fundamentals, segments, filing full-text.
# SEC requires a real contact in the User-Agent.
SEC_USER_AGENT=Your Name you@example.com
SEC_WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,META,AVGO,JPM,TSLA,WMT
USE_IXBRL_SEGMENTS=true
USE_SEC_EFTS=true

# AlphaSense (credentialed) — guidance, transcripts/expert calls, sentiment.
# Leave ALPHASENSE_API_KEY empty to disable (narrative/transcripts/sentiment
# then degrade to empty). OAuth2 password grant + x-api-key.
ALPHASENSE_API_KEY=
ALPHASENSE_CLIENT_ID=
ALPHASENSE_CLIENT_SECRET=
ALPHASENSE_USERNAME=
ALPHASENSE_PASSWORD=
ALPHASENSE_BASE_URL=https://api.alpha-sense.com
USE_ALPHASENSE=true

# Use mock clients when credentials are missing (demo mode)
USE_MOCKS=true

# Where generated DOCX + email artefacts go
OUTPUT_DIR=./out

# Azure Blob Storage (input + output persistence)
# Set AZURE_STORAGE_ACCOUNT_URL for managed-identity access (preferred)
# Or set AZURE_STORAGE_CONNECTION_STRING
# Leave both empty to use local filesystem (BLOB_LOCAL_ROOT) or no-op
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
BLOB_INPUT_CONTAINER=calorch-inputs
BLOB_OUTPUT_CONTAINER=calorch-outputs
BLOB_LOCAL_ROOT=./out/blobs

# Read pre-ingested data from blob storage instead of live API
USE_BLOB_PROVIDERS=true

# LangSmith (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=calorch
LANGSMITH_TRACING=true
