# Opencode Go (OpenAI-compatible endpoint, optional, overrides Azure when set)
# Available models: glm-5.1, glm-5, kimi-k2.5, kimi-k2.6, deepseek-v4-pro, deepseek-v4-flash
OPENCODE_GO_API_KEY=
OPENCODE_GO_MODEL=glm-5.1

# Azure OpenAI (used by llm_classify and event handlers)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Microsoft Graph (Entra ID app registration)
GRAPH_TENANT_ID=
GRAPH_CLIENT_ID=
GRAPH_CLIENT_SECRET=
GRAPH_USER_ID=me

# OneDrive (used for DOCX archive)
ONEDRIVE_DRIVE_ID=

# Storage backend: "json" (local) or "cosmos"
REPO_BACKEND=json
REPO_PATH=./out/repository.json
COSMOS_ENDPOINT=
COSMOS_KEY=
COSMOS_DB=calorch
COSMOS_CONTAINER=events

# Timer schedule for the Durable Functions orchestrator (NCRONTAB, with seconds)
CRON_SCHEDULE=0 0 9 * * 1

# Enterprise data providers (license already held)
FACTSET_API_KEY=
BLOOMBERG_BLPAPI_HOST=
LSEG_CLIENT_ID=
SPGLOBAL_API_KEY=

# Use mock clients when credentials are missing (demo mode)
USE_MOCKS=true

# Where generated DOCX + email artefacts go
OUTPUT_DIR=./out

# Azure Blob Storage (input + output persistence)
# Set AZURE_STORAGE_ACCOUNT_URL for managed-identity access (preferred)
# Or set AZURE_STORAGE_CONNECTION_STRING
# Leave both empty to use local filesystem (BLOB_LOCAL_ROOT) or no-op
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_URL=
BLOB_INPUT_CONTAINER=calorch-inputs
BLOB_OUTPUT_CONTAINER=calorch-outputs
BLOB_LOCAL_ROOT=./out/blobs

# Read pre-ingested data from blob storage instead of live API
USE_BLOB_PROVIDERS=true

# LangSmith (optional but recommended)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=calorch
LANGSMITH_TRACING=true
