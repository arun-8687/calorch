{
  "schema_version": "1.0",
  "event_type": "conference",
  "report_header": {
    "title": "CONFERENCE PREP PACK",
    "conference": "{conference_name}",
    "company": "{company_name} ({primary_ticker}) Meeting",
    "date": "{event_date} | {event_time}"
  },
  "metadata_table": {
    "table_type": "two_col",
    "rows": [
      {"label": "Last Price", "value": "{price}"},
      {"label": "Market Cap", "value": "{market_cap}"},
      {"label": "CEO", "value": "{ceo_name}"},
      {"label": "Employees", "value": "{employees}"},
      {"label": "Sector", "value": "{sector}"},
      {"label": "Consensus", "value": "{consensus_rating}"},
      {"label": "Price Target", "value": "{mean_target}"}
    ]
  },
  "sections": [
    {
      "id": "company_overview",
      "title": "Company Overview",
      "source": "llm",
      "llm_method": "enrich_headline",
      "fallback": ["{company_name} — {sector}. Conference meeting at {conference_name}."],
      "prompt_addendum": "Write a 4-5 sentence company overview for a conference 1x1 prep pack. Cover: business description, investment thesis, and why this meeting matters in the conference context."
    },
    {
      "id": "last_quarter",
      "title": "Last Quarter ({last_quarter_label})",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Revenue", "value": "{rev_actual}"},
        {"label": "EPS Actual vs Est", "value": "{eps_actual} vs {eps_estimate}"},
        {"label": "Net Income", "value": "{net_income}"},
        {"label": "Operating Income", "value": "{operating_income}"}
      ]
    },
    {
      "id": "recent_developments",
      "title": "Recent Developments",
      "source": "llm",
      "llm_method": "enrich_guidance",
      "fallback": ["Recent stock performance and key developments."],
      "prompt_addendum": "Write a concise paragraph (4-6 sentences) summarising recent developments. Cover: stock performance, major news, and any sector headwinds/tailwinds. Be factual."
    },
    {
      "id": "key_questions",
      "title": "Key Questions for {primary_ticker} Meeting",
      "source": "llm",
      "llm_method": "enrich_key_questions",
      "fallback": [],
      "prompt_addendum": "Write 6-8 themed questions for a conference 1x1 meeting. Each should be a short paragraph (2-3 sentences). Format as 'Topic: Content/question...' Cover: strategy, financials, competition, and sector-specific themes."
    },
    {
      "id": "note_template",
      "title": "Note-Taking Template",
      "source": "static",
      "table_type": "multi_col",
      "headers": ["Topic", "Notes", "Investment Implication"],
      "blank_rows": 7
    },
    {
      "id": "esg_governance",
      "title": "ESG & Governance",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Board Independence", "value": "{board_independence}"},
        {"label": "Executive Compensation", "value": "{exec_comp}"},
        {"label": "ESG Focus", "value": "{esg_focus}"},
        {"label": "Key Metric", "value": "{esg_key_metric}"}
      ]
    }
  ]
}
