{
  "schema_version": "1.0",
  "event_type": "management_meeting",
  "report_header": {
    "title": "MANAGEMENT MEETING BRIEFING",
    "company": "{company_name} ({primary_ticker})",
    "event": "Management 1:1",
    "date": "{event_date} | {event_time}"
  },
  "metadata_table": {
    "table_type": "two_col",
    "rows": [
      {"label": "Last Price", "value": "{price}"},
      {"label": "Market Cap", "value": "{market_cap}"},
      {"label": "CEO", "value": "{ceo_name}"},
      {"label": "Employees", "value": "{employees}"},
      {"label": "Sector", "value": "{sector}"},
      {"label": "Consensus", "value": "{consensus_rating} ({buy_buy}/{hold_hold}/{sell_sell})"},
      {"label": "Price Target", "value": "{mean_target} ({upside_pct}% upside)"}
    ]
  },
  "sections": [
    {
      "id": "company_overview",
      "title": "Company Overview",
      "source": "llm",
      "llm_method": "enrich_headline",
      "fallback": ["{company_name} — {sector}. Management 1:1 with {role}."],
      "prompt_addendum": "Write a 4-5 sentence company overview for a management meeting prep pack. Cover: business description, recent stock performance, key investment thesis points, and why this meeting matters. Be factual."
    },
    {
      "id": "last_quarter",
      "title": "Last Quarter ({last_quarter_label})",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Revenue", "value": "{rev_actual}"},
        {"label": "EPS (Diluted)", "value": "{eps_actual}"},
        {"label": "Key Metric 1", "value": "{key_metric_1}"},
        {"label": "Key Metric 2", "value": "{key_metric_2}"}
      ]
    },
    {
      "id": "recent_developments",
      "title": "Recent Developments",
      "source": "llm",
      "llm_method": "enrich_guidance",
      "fallback": ["Recent stock performance and key developments."],
      "prompt_addendum": "Write a concise paragraph (4-6 sentences) summarising recent developments for this company. Cover: stock performance, major news, strategic shifts, and any recent earnings highlights. Be factual with numbers."
    },
    {
      "id": "key_discussion_topics",
      "title": "Key Discussion Topics",
      "source": "llm",
      "llm_method": "enrich_key_questions",
      "fallback": [],
      "prompt_addendum": "Write 6-8 themed discussion topics for a management 1:1. Each should be a short paragraph (2-3 sentences) covering a strategic topic. Format as 'Topic: Content/question...' Topics should cover: strategy, financials, competition, capital allocation, product roadmap, and risks."
    },
    {
      "id": "follow_up_template",
      "title": "Follow-Up Template",
      "source": "static",
      "table_type": "multi_col",
      "headers": ["Topic", "Key Takeaway", "Action Item", "Owner", "Due Date"],
      "blank_rows": 5
    },
    {
      "id": "financial_summary",
      "title": "Financial Summary",
      "source": "data",
      "table_type": "two_col",
      "rows": [
        {"label": "Revenue Growth YoY", "value": "{rev_growth}"},
        {"label": "Operating Margin", "value": "{operating_margin}"},
        {"label": "Key Segment Growth", "value": "{segment_growth}"},
        {"label": "P/E Ratio", "value": "{pe_ttm}"}
      ]
    }
  ]
}
